{
  "expo": {
    "name": "VoiceBridge",
    "slug": "VoiceBridge",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "voicebridge",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Voice Bridge uses voice playback features for communication support."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "extra": {
      "firebaseApiKey": "AIzaSyBDKVVGgBmXuXKdfgZGpxYlckjfH0r5IsE",
      "firebaseAuthDomain": "voicebridge-9b831.firebaseapp.com",
      "firebaseProjectId": "voicebridge-9b831",
      "firebaseStorageBucket": "voicebridge-9b831.firebasestorage.app",
      "firebaseMessagingSenderId": "617294389624",
      "firebaseAppId": "1:617294389624:web:55668cf16828ea91e4688d",
      "firebaseMeasurementId": "G-SJ7W11LMJJ",
      "firebaseVapidKey": ""
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
